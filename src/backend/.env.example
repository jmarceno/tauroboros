# TaurOboros Rust Server Configuration

# Server port (default: 3789)
# SERVER_PORT=3789

# Database path (default: .tauroboros/tasks.db)
# DATABASE_PATH=.tauroboros/tasks.db

# Project root directory (default: current directory)
# PROJECT_ROOT=/path/to/your/project

# Logging level: error, warn, info, debug, trace (default: info)
# RUST_LOG=info
