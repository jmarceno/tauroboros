{
  "name": "pi-easy-workflow",
  "version": "1.0.0",
  "description": "Pi-based Easy Workflow scaffolding",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --target=bun src/index.ts --outdir dist",
    "test": "bun test",
    "skills:sync": "bun run scripts/sync-skills.ts",
    "skills:install": "bun run scripts/sync-skills.ts --clean",
    "skills:verify": "bun run scripts/verify-setup.ts",
    "setup": "bun run skills:install && bun run skills:verify"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.11"
  }
}
