{
  "name": "tauroboros",
  "version": "0.1.0",
  "description": "TaurOboros - AI-powered workflow orchestration system",
  "type": "module",
  "scripts": {
    "rust:bundle": "cd src/backend && cargo build --release",
    "kanban:build": "cd src/frontend && bun install --no-save && bun run build",
    "kanban:dev": "cd src/frontend && bun install --no-save && bun run dev",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:debug": "bunx playwright test --debug",
    "test:e2e:headed": "bunx playwright test --headed",
    "skills:sync": "bun run scripts/sync-skills.ts",
    "skills:install": "bun run scripts/sync-skills.ts --clean",
    "test:e2e:mock": "bun run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0"
  }
}
