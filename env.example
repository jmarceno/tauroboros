# Pi Easy Workflow Configuration

# =============================================================================
# Runtime Selection
# =============================================================================
# Choose between native (spawn pi directly) or container (Podman isolation)
PI_EASY_WORKFLOW_RUNTIME=native

# =============================================================================
# Container Settings (only used when RUNTIME=container)
# =============================================================================
# Podman image for pi-agent
PI_EASY_WORKFLOW_CONTAINER_IMAGE=pi-agent:alpine

# Resource limits per container
PI_EASY_WORKFLOW_CONTAINER_MEMORY_MB=512
PI_EASY_WORKFLOW_CONTAINER_CPU_COUNT=1

# =============================================================================
# Port Isolation
# =============================================================================
# Port range for automatic host port allocation
PI_EASY_WORKFLOW_PORT_RANGE_START=30000
PI_EASY_WORKFLOW_PORT_RANGE_END=40000

# =============================================================================
# Pi Binary Configuration
# =============================================================================
# Path to pi binary (default: "pi" from PATH)
PI_EASY_WORKFLOW_PI_BIN=pi

# Additional arguments for pi (default: --mode rpc --no-extensions)
# PI_EASY_WORKFLOW_PI_ARGS=--mode rpc --no-extensions

# =============================================================================
# Example: Enable container mode with custom settings
# =============================================================================
# PI_EASY_WORKFLOW_RUNTIME=container
# PI_EASY_WORKFLOW_CONTAINER_IMAGE=pi-agent:alpine
# PI_EASY_WORKFLOW_CONTAINER_MEMORY_MB=1024
# PI_EASY_WORKFLOW_CONTAINER_CPU_COUNT=2
# PI_EASY_WORKFLOW_PORT_RANGE_START=30000
# PI_EASY_WORKFLOW_PORT_RANGE_END=40000
